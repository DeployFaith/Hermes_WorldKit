{
  "id": "hermes_chat",
  "name": "Hermes Chat",
  "version": "0.1.0",
  "hermes_ui": "0.1",
  "icon": "res://addons/hermes_os/assets/icons/circle-help.svg",
  "entry": "main.hml",
  "styles": ["main.hss"],
  "controller": "main.gd",
  "surface": "window",
  "window": {
    "title": "Hermes Chat",
    "size_class": "workspace",
    "default_width": 1080,
    "default_height": 720,
    "min_width": 840,
    "min_height": 560,
    "resizable": true,
    "chromed": true
  },
  "permissions": [
    "gateway.chat"
  ]
}
